<Window x:Class="SimpleViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleViewer" Height="800" Width="1200"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        AllowDrop="True" Drop="Window_Drop" Focusable="True">

    <!--
        MainWindow.xaml の説明
        - このウィンドウはシンプルなイメージビューアのメイン UI を構成します。
        - 上部にメニュー、下部にステータスバー（スライダー含む）、左にサイドバー、
          右にメインのイメージ表示領域（スクロール可能）を配置しています。
    -->

    <Window.Resources>
        <!-- モダンスライダーのスタイル定義 -->
        <Style x:Key="ModernSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <!-- スライダーのトラック背景 -->
                            <Border x:Name="TrackBackground" Height="10" Margin="5,0" 
                                    Background="#CCCCCC" CornerRadius="5" VerticalAlignment="Center"/>

                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <!-- トラック減少側のビジュアル -->
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Background="#007ACC" Height="10" CornerRadius="5,0,0,5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <!-- スライダーつまみ（サム）のテンプレート -->
                                    <Thumb Width="24" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Grid>
                                                    <Ellipse Fill="White" Stroke="#007ACC" StrokeThickness="2">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Fill="#007ACC" Width="10" Height="10"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- メニュー全体とメニューアイテムの基本スタイル -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.MenuBarBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.MenuTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <DockPanel LastChildFill="True">

            <!-- アプリ上部のメニュー -->
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="ファイル(_F)">
                    <MenuItem Header="開く(_O)..." Click="MenuOpen_Click" InputGestureText="Ctrl+O"/>
                    <MenuItem Header="閉じる(_C)" Click="MenuClose_Click" InputGestureText="Ctrl+W"/>
                    <Separator/>
                    <MenuItem Header="終了(_X)" Click="MenuExit_Click" InputGestureText="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="表示(_V)">
                    <MenuItem Header="カタログ表示(_C)" Click="MenuCatalog_Click" InputGestureText="F3"/>
                    <MenuItem Header="サイドバー切替(_S)" Click="MenuToggleSidebar_Click" InputGestureText="F4"/>
                    <MenuItem Header="表示モード切替(_M)" Click="MenuToggleMode_Click" InputGestureText="S"/>
                    <Separator/>
                    <MenuItem Header="ズームイン" Click="MenuZoomIn_Click" InputGestureText="Ctrl++"/>
                    <MenuItem Header="ズームアウト" Click="MenuZoomOut_Click" InputGestureText="Ctrl+-"/>
                    <MenuItem Header="実寸 (100%)" Click="MenuResetZoom_Click" InputGestureText="Ctrl+0"/>
                    <MenuItem Header="ウィンドウ幅に合わせる" Click="MenuFitWidth_Click" InputGestureText="Ctrl+F"/>
                    <MenuItem Header="ウィンドウ全体に合わせる" Click="MenuFitPage_Click" InputGestureText="Ctrl+G"/>
                </MenuItem>
                <MenuItem Header="設定(_T)">
                    <MenuItem x:Name="MenuApplyExifOrientation" Header="EXIF Orientationを適用(_E)" 
                              IsCheckable="True" IsChecked="True" Click="MenuApplyExifOrientation_Click"/>
                </MenuItem>
            </Menu>

            <!-- ステータスバーとページナビゲーション -->
            <Border DockPanel.Dock="Bottom" 
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" 
                    BorderThickness="0,1,0,0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 現在のページ表示（例: 1 / 10） -->
                    <TextBlock x:Name="StatusText" Text="0 / 0" VerticalAlignment="Center" FontWeight="Bold"/>

                    <!-- ページ移動用スライダー -->
                    <Slider x:Name="PageSlider" Grid.Column="1" VerticalAlignment="Center" Height="30"
                            Style="{StaticResource ModernSliderStyle}"
                            Focusable="False" Minimum="0" IsMoveToPointEnabled="True" 
                            FlowDirection="RightToLeft" PreviewMouseLeftButtonUp="PageSlider_PreviewMouseLeftButtonUp"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- 現在の表示モード（単一表示、見開きなど） -->
                        <TextBlock x:Name="ModeText" Text="単一表示" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold"/>
                        <!-- ズーム表示（クリックでリセット） -->
                        <Button Click="MenuResetZoom_Click" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock x:Name="ZoomText" Text="100%" Width="80" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- サイドバー列（サムネイルやツリー） -->
                    <ColumnDefinition x:Name="SidebarColumn" Width="200" MinWidth="0"/>
                    <ColumnDefinition Width="4"/>
                    <!-- メイン表示エリア -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左側サイドバー（タブコントロールでサムネとツリーを切替） -->
                <Border Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}" 
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,0,1,0">
                    <TabControl>
                        <TabItem Header="サムネイル">
                            <!--
                                ItemsControl のスクロールを物理スクロール（ピクセル単位）に設定。
                                大量のサムネイルでも安定動作するよう、仮想化は控えめに設定。
                            -->
                            <ItemsControl x:Name="ThumbnailSidebar" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <Border Background="Transparent">
                                            <ScrollViewer CanContentScroll="False" VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </Border>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                            </ItemsControl>
                        </TabItem>
                        <TabItem Header="ツリー">
                            <!-- フォルダやファイル構成を表示するツリービュー -->
                            <TreeView x:Name="SidebarTreeView" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </TabItem>
                    </TabControl>
                </Border>

                <!-- 列の区切り（ドラッグでサイズ変更可能） -->
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

                <!-- メイン表示領域：スクロール可能で中央に画像を配置 -->
                <ScrollViewer x:Name="MainScrollViewer" Grid.Column="2" Background="Black" 
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              SizeChanged="MainScrollViewer_SizeChanged"
                              PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel"
                              PreviewMouseLeftButtonDown="MainScrollViewer_MouseLeftButtonDown"
                              MouseMove="MainScrollViewer_MouseMove"
                              PreviewMouseLeftButtonUp="MainScrollViewer_PreviewMouseLeftButtonUp">
                    <Grid x:Name="ViewContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- 横並びで2つの Image を配置（見開き表示対応） -->
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="ImageLeft" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Image x:Name="ImageRight" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </DockPanel>

        <!-- カタログオーバーレイ（表示/非表示を切替） -->
        <Grid x:Name="CatalogOverlay" Visibility="Collapsed" Background="#F2000000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Padding="20,10">
                <Grid>
                    <TextBlock Text="カタログ一覧" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="閉じる (Esc)" HorizontalAlignment="Right" Padding="20,8" Click="CloseCatalog_Click"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <!-- カタログのサムネイルを WrapPanel に追加 -->
                <WrapPanel x:Name="CatalogPanel" HorizontalAlignment="Center" Margin="20"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>