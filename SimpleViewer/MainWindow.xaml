<Window x:Class="SimpleViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleViewer"
        Width="1200"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        Focusable="True"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="10"
                          ShadowDepth="0"
                          Opacity="0.04"
                          Color="#FF0F172A"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="SidebarBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="HeaderMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="HeaderMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Grid>
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,6,0,0"
                                            Padding="6"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Effect="{StaticResource CardShadow}">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Margin" Value="0"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThumbnailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ThumbnailBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ThumbnailBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ThumbnailBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6"
                                    Margin="10,0"
                                    Background="{DynamicResource BorderBrush}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6"
                                                        Margin="10,0,0,0"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="3,0,0,3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Fill="White" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"/>
                                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="8,0,8,0"
                Padding="7,4"
                Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Right"
                        Padding="7,3"
                        Background="{DynamicResource SurfaceAltBrush}"
                        CornerRadius="7">
                    <TextBlock Text="SimpleViewer" FontWeight="SemiBold" FontSize="11"/>
                </Border>

                <Menu DockPanel.Dock="Left"
                      Style="{StaticResource HeaderMenuStyle}"
                      ItemContainerStyle="{StaticResource HeaderMenuItemStyle}">
                    <MenuItem Header="ファイル(_F)">
                        <MenuItem Header="開く(_O)..." Click="MenuOpen_Click" InputGestureText="Ctrl+O"/>
                        <MenuItem Header="閉じる(_C)" Click="MenuClose_Click" InputGestureText="Ctrl+W"/>
                        <Separator/>
                        <MenuItem Header="終了(_X)" Click="MenuExit_Click" InputGestureText="Alt+F4"/>
                    </MenuItem>
                    <MenuItem Header="表示(_V)">
                        <MenuItem Header="カタログ表示(_C)" Click="MenuCatalog_Click" InputGestureText="F3"/>
                        <MenuItem Header="サイドバー切替(_S)" Click="MenuToggleSidebar_Click" InputGestureText="F4"/>
                        <MenuItem Header="表示モード切替(_M)" Click="MenuToggleMode_Click" InputGestureText="S"/>
                        <Separator/>
                        <MenuItem Header="ズームイン" Click="MenuZoomIn_Click" InputGestureText="Ctrl++"/>
                        <MenuItem Header="ズームアウト" Click="MenuZoomOut_Click" InputGestureText="Ctrl+-"/>
                        <MenuItem Header="実寸 (100%)" Click="MenuResetZoom_Click" InputGestureText="Ctrl+0"/>
                        <MenuItem Header="ウィンドウ幅に合わせる" Click="MenuFitWidth_Click" InputGestureText="Ctrl+F"/>
                        <MenuItem Header="ウィンドウ全体に合わせる" Click="MenuFitPage_Click" InputGestureText="Ctrl+G"/>
                    </MenuItem>
                    <MenuItem Header="設定(_T)">
                        <MenuItem x:Name="MenuApplyExifOrientation"
                                  Header="EXIF Orientationを適用(_E)"
                                  IsCheckable="True"
                                  IsChecked="True"
                                  Click="MenuApplyExifOrientation_Click"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="8,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="220" MinWidth="0"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SidebarBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="8,7,8,4" LastChildFill="False">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="ナビゲーション"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="F4"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <TabControl Grid.Row="1"
                                Margin="5,0,5,5"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource SidebarTabItemStyle}"/>
                        </TabControl.Resources>
                        <TabItem Header="サムネイル">
                            <ItemsControl x:Name="ThumbnailSidebar" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <Border Margin="0,4,0,0" Background="Transparent">
                                            <ScrollViewer CanContentScroll="False" VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </Border>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                            </ItemsControl>
                        </TabItem>
                        <TabItem Header="ツリー">
                            <TreeView x:Name="SidebarTreeView"
                                      Margin="0,4,0,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <ScrollViewer x:Name="MainScrollViewer"
                              Margin="0"
                              Padding="0"
                              Background="{DynamicResource ViewerBackgroundBrush}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              SizeChanged="MainScrollViewer_SizeChanged"
                              PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel"
                              PreviewMouseLeftButtonDown="MainScrollViewer_MouseLeftButtonDown"
                              MouseMove="MainScrollViewer_MouseMove"
                              PreviewMouseLeftButtonUp="MainScrollViewer_PreviewMouseLeftButtonUp">
                    <Grid x:Name="ViewContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="ImageLeft" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Image x:Name="ImageRight" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="8,0,8,5"
                Padding="8,5"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="214"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ページ" Style="{StaticResource SecondaryTextStyle}"/>
                    <TextBlock x:Name="StatusText" Margin="0,1,0,0" Text="0 / 0" FontSize="15" FontWeight="Bold"/>
                </StackPanel>

                <Slider x:Name="PageSlider"
                        Grid.Column="1"
                        Height="24"
                        VerticalAlignment="Center"
                        Focusable="False"
                        Minimum="0"
                        IsMoveToPointEnabled="True"
                        FlowDirection="RightToLeft"
                        PreviewMouseLeftButtonUp="PageSlider_PreviewMouseLeftButtonUp"
                        Style="{StaticResource ModernSliderStyle}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Margin="0,0,6,0"
                            Padding="7,5"
                            Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="8">
                        <TextBlock x:Name="ModeText" Text="単一表示" FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                    <Button Click="MenuResetZoom_Click" Style="{StaticResource GhostButtonStyle}" Padding="9,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,5,0" Text="ズーム" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ZoomText" Width="54" Text="100%" TextAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="CatalogOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="10"
              Visibility="Collapsed"
              Background="{DynamicResource OverlayBrush}">
            <Grid Margin="20">
                <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="16,12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="12,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="カタログ一覧"/>
                                    <TextBlock Margin="0,2,0,0"
                                               Text="一覧から任意のページを選択できます。"
                                               Style="{StaticResource SecondaryTextStyle}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        MinHeight="0"
                                        Padding="12,5"
                                        Click="CloseCatalog_Click"
                                        Style="{StaticResource GhostButtonStyle}">
                                    <TextBlock Text="閉じる (Esc)" FontSize="12"/>
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="CatalogPanel" HorizontalAlignment="Center" Margin="14"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>